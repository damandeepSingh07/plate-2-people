# 🎯 PLATE2PEOPLE FRONTEND CONFIGURATION

# ============================================
# SOCKET.IO CONFIGURATION
# ============================================
# Socket.io server URL for real-time features
# Options:
#   http://localhost:8000  - If Socket.io runs on same port as Django (requires server setup)
#   http://localhost:3001  - If separate Node.js Socket.io server on port 3001
# Default: http://localhost:8000
VITE_SOCKET_URL=http://localhost:8000

# ============================================
# API CONFIGURATION
# ============================================
# Django REST API Base URL
# Default: http://localhost:8000/api
VITE_API_URL=http://localhost:8000/api

# ============================================
# GOOGLE MAPS API
# ============================================
# Get free API key from: https://console.cloud.google.com
# Enable these APIs:
#   - Maps JavaScript API
#   - Directions API
#   - Places API
# REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
# Enable/disable real-time features
# If Socket.io not available, set to false
# VITE_ENABLE_REALTIME=true

# ============================================
# DEVELOPMENT
# ============================================
# Set to true for verbose console logging
# VITE_DEBUG=false
