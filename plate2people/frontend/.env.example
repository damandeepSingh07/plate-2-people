# ============================================
# SOCKET.IO CONFIGURATION
# ============================================
# Socket.io server URL for real-time features
# Default: http://localhost:8000
# 
# Options:
#   - http://localhost:8000  (Django with Socket.io)
#   - http://localhost:3001  (Separate Node.js Socket.io server)
#
# If Socket.io server not running, app works with REST API polling
VITE_SOCKET_URL=http://localhost:8000

# ============================================
# API Configuration
# ============================================
# Django REST API Base URL
# Default: http://localhost:8000/api
VITE_API_URL=http://localhost:8000/api

# ============================================
# GOOGLE MAPS API KEY
# ============================================
# Get your free API key from: https://console.cloud.google.com
# Make sure to enable:
#   - Maps JavaScript API
#   - Directions API
#   - Places API
# REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
# Enable/disable real-time features
# If Socket.io unavailable, will automatically use REST API fallback
# VITE_ENABLE_REALTIME=true

# ============================================
# DEVELOPMENT
# ============================================
# Set to true for verbose console logging
# VITE_DEBUG=false

